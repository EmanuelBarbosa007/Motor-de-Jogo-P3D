mtllib mesa.mtl
usemtl CorVerde

# Coordenadas dos 8 cantos do paralelepípedo (Vertices)
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v -1.0  1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0 -1.0
v  1.0  1.0 -1.0
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0

# Coordenadas das Normais (Para a luz refletir direito nas 6 faces)
vn  0.0  0.0  1.0
vn  0.0  1.0  0.0
vn  0.0  0.0 -1.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# Coordenadas UV (Para não dar erro no Shader)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Ligar os pontos para formar as 6 faces do paralelepípedo
f 1/1/1 2/2/1 4/3/1
f 1/1/1 4/3/1 3/4/1
f 3/1/2 4/2/2 6/3/2
f 3/1/2 6/3/2 5/4/2
f 5/1/3 6/2/3 8/3/3
f 5/1/3 8/3/3 7/4/3
f 7/1/4 8/2/4 2/3/4
f 7/1/4 2/3/4 1/4/4
f 2/1/5 8/2/5 6/3/5
f 2/1/5 6/3/5 4/4/5
f 7/1/6 1/2/6 3/3/6
f 7/1/6 3/3/6 5/4/6